        given-names: Gonçalo
    title: "Freedom as Navigability: A Ratio Law Unifying Swarm Intelligence, Gradient Dynamics, and Complex Adaptive Systems"
    year: 2026
    journal: "SSRN Electronic Journal"
    doi: "10.2139/ssrn.5137338"
